DB_PATH=./data/db.json
JWT_SECRET=change-this-to-a-random-64-char-string

ADMIN_EMAIL=admin@aiuniverse.com
ADMIN_PASSWORD=Admin@123

# ── LLM Provider ── choose one ────────────────────────────────────────────────
# Options: openai | groq | gemini | anthropic | dummy
LLM_PROVIDER=groq
# groq  → get free key at console.groq.com/keys    (recommended - free)
# gemini → get free key at aistudio.google.com/apikey
# openai → get key at platform.openai.com/api-keys  (paid, credits needed)
LLM_API_KEY=your-api-key-here

FRONTEND_URL=http://localhost:5173
